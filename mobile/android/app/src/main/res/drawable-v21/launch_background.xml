<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/launch_glow_bottom"
                android:startColor="@color/launch_background" />
        </shape>
    </item>
    <item android:top="-140dp" android:left="-72dp" android:right="-72dp">
        <shape android:shape="oval">
            <size android:width="420dp" android:height="420dp" />
            <gradient
                android:centerColor="#00163F2C"
                android:endColor="#00163F2C"
                android:gradientRadius="210dp"
                android:startColor="#5C163F2C"
                android:type="radial" />
        </shape>
    </item>
    <item android:bottom="-180dp" android:left="-40dp" android:right="-40dp">
        <shape android:shape="oval">
            <size android:width="360dp" android:height="360dp" />
            <gradient
                android:centerColor="#0009140E"
                android:endColor="#0009140E"
                android:gradientRadius="180dp"
                android:startColor="#88132C20"
                android:type="radial" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="132dp" android:height="132dp" />
            <gradient
                android:angle="270"
                android:endColor="#1AFFFFFF"
                android:startColor="#14FFFFFF" />
            <stroke android:width="1dp" android:color="#24FFFFFF" />
        </shape>
    </item>
    <item android:gravity="center">
        <inset
            android:drawable="@drawable/splash_brand_mark"
            android:insetBottom="26dp"
            android:insetLeft="26dp"
            android:insetRight="26dp"
            android:insetTop="26dp" />
    </item>
</layer-list>
